{
  "name": "cypress-cucumber-e2e-tests",
  "version": "1.0.0",
  "description": "Cypress Cucumber E2E Test Framework",
  "main": "index.js",
  "scripts": {
    "prepare": "husky",
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean": "npm run clean:results && npm run clean:modules",
    "clean:modules": "rimraf ./node_modules",
    "clean:results": "rimraf ./cypress/reports ./cypress/videos ./cypress/screenshots ./cypress/downloads",
    "cy:open:prod": "npx cypress open --env ENV=prod",
    "cy:open:local": "npx cypress open --env ENV=local",
    "cy:run:prod": "npx cypress run --env ENV=prod",
    "cy:run:local": "npx cypress run --env ENV=local",
    "docker:build": "docker build . -t e2e",
    "allure:generate": "allure generate cypress/reports/allure-results -o cypress/reports/allure-report --clean",
    "allure:generate:html": "allure generate --single-file cypress/reports/allure-results -o cypress/reports/allure-report-html --clean",
    "allure:open": "allure open cypress/reports/allure-report"
  },
  "keywords": [
    "Cypress",
    "JS",
    "JavaScript",
    "Cucumber",
    "Gherkin"
  ],
  "author": "Levi9",
  "license": "ISC",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "allure-commandline": "^2.42.1",
    "allure-cypress": "^3.10.0",
    "allure-js-commons": "^3.10.0",
    "cypress": "^15.17.0",
    "cypress-on-fix": "^1.1.0",
    "cypress-split": "^1.25.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-chai-friendly": "^1.2.1",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "uuid": "^14.0.0"
  },
  "overrides": {
    "eslint-plugin-import": {
      "eslint": "$eslint",
      "@eslint/js": "$@eslint/js"
    }
  }
}
